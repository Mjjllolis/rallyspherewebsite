# Retrieve your GA ID from your GA dashboard
GOOGLE_ANALYTICS_ID=G-XXXXXXX

# Contact form → Microsoft Graph (free; no premium connector).
# Copy to .env.local for local dev, and add the same vars in Vercel project settings.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# A real mailbox in your tenant the message is SENT FROM (e.g. noreply@yourdomain.com)
MAIL_FROM=
# Where you want to RECEIVE submissions (can be the same as MAIL_FROM)
MAIL_TO=
